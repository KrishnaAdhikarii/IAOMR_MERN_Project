# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/iaomr_convention
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/iaomr_convention

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@iaomr2026.com

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@iaomr2026.com
ADMIN_PASSWORD=Admin@2026
